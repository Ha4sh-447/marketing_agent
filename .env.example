OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq — get free key at https://console.groq.com/keys (no credit card needed)
GROQ_API_KEY=gsk_your-groq-key-here

# ── OpenRouter primary models (lightweight-to-heavyweight hierarchy) ─────
# Planner (Base / Lightweight 9B model - extremely fast)
PLANNER_MODEL=google/gemma-4-31b-it:free

# Generator (Medium / Highly creative 70B writing model)
GENERATOR_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Evaluator (Heavy / Skeptical 120B clinical QA reasoning model)
EVALUATOR_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── OpenRouter secondary fallbacks (used when primary is rate-limited) ─
PLANNER_MODEL_FALLBACK=meta-llama/llama-3.2-3b-instruct:free
GENERATOR_MODEL_FALLBACK=moonshotai/kimi-k2.6:free
EVALUATOR_MODEL_FALLBACK=qwen/qwen3-next-80b-a3b-instruct:free

# ── Groq fallbacks (last resort — fast inference, separate rate limits) ─
PLANNER_GROQ_MODEL=llama-3.1-8b-instant
GENERATOR_GROQ_MODEL=llama-3.3-70b-versatile
EVALUATOR_GROQ_MODEL=llama-3.3-70b-versatile

SITE_URL=http://localhost:8000
SITE_NAME=Marketing Agent
MAX_SCRAPE_PAGES=8
MAX_RETRIES_PER_POST=5
