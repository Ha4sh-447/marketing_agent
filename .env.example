NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── NVIDIA NIM models (free preview endpoints) ───────────────
# Planner (largest available models for structured reasoning)
PLANNER_MODEL=mistralai/mistral-large-3-675b-instruct-2512
PLANNER_MODEL_FALLBACK=minimaxai/minimax-m2.7

# Generator (fast, instruction-following models for copywriting)
GENERATOR_MODEL=stepfun-ai/step-3.7-flash
GENERATOR_MODEL_FALLBACK=stepfun-ai/step-3.5-flash

# Evaluator (large, critical judgment models)
EVALUATOR_MODEL=minimaxai/minimax-m2.7
EVALUATOR_MODEL_FALLBACK=mistralai/mistral-large-3-675b-instruct-2512

SITE_URL=http://localhost:8000
SITE_NAME=Marketing Agent
MAX_SCRAPE_PAGES=8
MAX_RETRIES_PER_POST=5
