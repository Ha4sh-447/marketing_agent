# ── Provider API Keys ──────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

NVIDIA_API_KEY=your-nvidia-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

GROQ_API_KEY=your-groq-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1

MISTRAL_API_KEY=your-mistral-key-here
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ── Primary Models (OpenRouter / NVIDIA) ───────────────────────
# Planner (largest available models for structured reasoning)
PLANNER_MODEL=google/gemma-2-27b-it:free
PLANNER_MODEL_FALLBACK=openai/gpt-oss-120b:free

# Generator (fast, instruction-following models for copywriting)
GENERATOR_MISTRAL_MODEL=mistral-large-latest
GENERATOR_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
GENERATOR_MODEL_FALLBACK=google/gemma-2-9b-it:free

# Evaluator (large, critical judgment models)
EVALUATOR_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
EVALUATOR_MODEL_FALLBACK=google/gemma-2-9b-it:free

# ── Groq Models (Fast Fallbacks) ───────────────────────────────
PLANNER_GROQ_MODEL=llama-3.3-70b-versatile
GENERATOR_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EVALUATOR_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── App Settings ───────────────────────────────────────────────
SITE_URL=http://localhost:8000
SITE_NAME="Marketing Agent"
MAX_SCRAPE_PAGES=8
MAX_RETRIES_PER_POST=5
DB_PATH=data/marketing.db
